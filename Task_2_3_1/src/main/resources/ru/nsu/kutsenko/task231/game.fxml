<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="10"
      style="-fx-padding: 10; -fx-background-color: #f0f0f0;"
      alignment="TOP_CENTER">

    <HBox spacing="10" style="-fx-padding: 10;" alignment="CENTER">
        <Label fx:id="infoLabel"
               text="State: RUNNING | Length: 1 | Food: 3 | Goal: 50"
               style="-fx-font-size: 14; -fx-padding: 10;"/>
        <Button fx:id="restartButton"
                text="Restart Game"
                style="-fx-font-size: 14; -fx-padding: 10;"
                visible="false"
                focusTraversable="false"/>
    </HBox>
</VBox>